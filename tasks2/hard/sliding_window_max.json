{
  "id": "sliding_window_max",
  "name": "Sliding Window Maximum",
  "difficulty": "hard",
  "description": "You are given an array of integers nums, there is a sliding window of size k which is moving from the very left of the array to the very right. You can only see the k numbers in the window. Each time the sliding window moves right by one position. Return the max sliding window.",
  "signature": "def max_sliding_window(nums: list[int], k: int) -> list[int]:",
  "tests": [
    "def test_basic():\n    assert max_sliding_window([1,3,-1,-3,5,3,6,7], 3) == [3,3,5,5,6,7]",
    "def test_single_element():\n    assert max_sliding_window([1], 1) == [1]",
    "def test_k_equals_length():\n    assert max_sliding_window([1,3,2], 3) == [3]",
    "def test_decreasing():\n    assert max_sliding_window([9,8,7,6,5], 2) == [9,8,7,6]",
    "def test_increasing():\n    assert max_sliding_window([1,2,3,4,5], 2) == [2,3,4,5]",
    "def test_all_same():\n    assert max_sliding_window([5,5,5,5], 2) == [5,5,5]",
    "def test_k_equals_one():\n    assert max_sliding_window([4,2,7,1,3], 1) == [4,2,7,1,3]",
    "def test_negatives():\n    assert max_sliding_window([-1,-3,-5,-2,-4], 3) == [-1,-2,-2]"
  ],
  "constraints": [
    "1 <= nums.length <= 10^5",
    "-10^4 <= nums[i] <= 10^4",
    "1 <= k <= nums.length",
    "Expected O(n) complexity using deque"
  ],
  "tags": ["sliding-window", "deque", "monotonic-queue"]
}

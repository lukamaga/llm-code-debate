{
  "id": "binary_search",
  "name": "Binary Search",
  "difficulty": "easy",
  "description": "Given a sorted array of integers and a target value, return the index of the target if it is present in the array, or -1 if it is not.",
  "signature": "def binary_search(nums: list[int], target: int) -> int:",
  "tests": [
    "def test_found_middle():\n    assert binary_search([1, 3, 5, 7, 9], 5) == 2",
    "def test_found_first():\n    assert binary_search([1, 3, 5, 7, 9], 1) == 0",
    "def test_found_last():\n    assert binary_search([1, 3, 5, 7, 9], 9) == 4",
    "def test_not_found():\n    assert binary_search([1, 3, 5, 7, 9], 4) == -1",
    "def test_empty_list():\n    assert binary_search([], 5) == -1",
    "def test_single_found():\n    assert binary_search([5], 5) == 0",
    "def test_single_not_found():\n    assert binary_search([5], 3) == -1",
    "def test_two_elements():\n    assert binary_search([1, 3], 3) == 1"
  ],
  "constraints": [
    "nums is sorted in ascending order",
    "0 <= len(nums) <= 10000",
    "-10000 <= nums[i] <= 10000"
  ]
}
